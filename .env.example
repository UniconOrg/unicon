# =============================================================================
# Variables de entorno - Unicon Landing
# Copia este archivo como .env y ajusta los valores
# =============================================================================

# Entorno de ejecucion (development | production)
NODE_ENV=development

# Zona horaria del contenedor
APP_TIMEZONE=America/Mexico_City

# Puerto expuesto en el host (el contenedor siempre usa 3000 internamente)
APP_PORT=3001

# URL base de la API backend (server-only, no exponer al cliente)
API_BASE_URL=
